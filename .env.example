# Titan Protocol — Environment Variables
# Copy this file to .env and fill in real values (never commit .env).
# Most of these are populated in later phases — see ROADMAP.md.

# === Supabase (Phase 3 — cloud migration) ===
# Project: Titan Protocol (ref: rmvodrpgaffxeultskst, region: ap-south-1)
# These values are publishable (gated by RLS policies on every table) but
# still belong in .env for convention. Copy them to .env to use.
EXPO_PUBLIC_SUPABASE_URL=https://rmvodrpgaffxeultskst.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_Vuwd5-jaCnOWpbY3FP0D7w_3ZoVMMNX

# === RevenueCat (Phase 4.1 — subscription billing) ===
# Get from https://app.revenuecat.com → Project → Apps → Android SDK Key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# === PostHog (Phase 4.4 — analytics) ===
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# === Sentry (Phase 4.4 — error tracking) ===
SENTRY_DSN=
# Only needed for uploading source maps during EAS build
SENTRY_AUTH_TOKEN=

# === Google Sign-In OAuth client IDs (Phase 3.2) ===
# Generate in Google Cloud Console with SHA-1 from titan-release.jks
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
