{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/typecheck-on-commit.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(npx tsc*)",
      "Bash(npm test*)",
      "Bash(npm run typecheck*)",
      "Bash(npx jest*)",
      "Bash(npx expo*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(df *)",
      "mcp__claude_ai_Supabase__list_tables",
      "mcp__claude_ai_Supabase__execute_sql",
      "mcp__claude_ai_Supabase__generate_typescript_types",
      "mcp__claude_ai_Supabase__get_advisors",
      "mcp__claude_ai_Supabase__list_migrations",
      "mcp__claude_ai_Supabase__get_project_url",
      "mcp__claude_ai_Supabase__get_publishable_keys"
    ]
  }
}
