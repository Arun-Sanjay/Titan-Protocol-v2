{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "command": "if echo \"$TOOL_INPUT\" | grep -q 'git commit'; then npx tsc --noEmit; fi",
        "description": "TypeScript check before commit"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(npx tsc*)",
      "Bash(npm test*)",
      "Bash(npx jest*)",
      "Bash(npx expo*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(df*)",
      "mcp__claude_ai_Supabase__list_tables",
      "mcp__claude_ai_Supabase__execute_sql",
      "mcp__claude_ai_Supabase__generate_typescript_types",
      "mcp__claude_ai_Supabase__get_advisors"
    ]
  }
}
